# Supabase (frontend) — expostas no client, use apenas a anon/publishable key
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# --- Variáveis abaixo NÃO vão para o frontend ---
# Configuradas como secrets da Edge Function `alertas` (supabase secrets set ...)

# Provedor de e-mail (ex.: Resend)
EMAIL_API_KEY=
EMAIL_FROM="Homologacao Sumare <homologacao@exemplo.com.br>"
# Destinatário interno responsável pelos alertas de vencimento
ALERTA_DESTINATARIO=compras@exemplo.com.br
